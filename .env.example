# SkyGuard — Environment Variables
# ===================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is in .gitignore.
#
# cp .env.example .env

# ── AI Agents ─────────────────────────────────────────────────────────────────
# Required for live AI analysis (Pentest Narrator, Threat Modeller, Compliance Mapper).
# Without this key, agents run in deterministic fallback mode — all tests still pass.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# ── EFB API ───────────────────────────────────────────────────────────────────
# Flask environment — set to 'production' to disable the /debug endpoint (W4 fix demo).
FLASK_ENV=development

# EFB API port (default: 5050)
EFB_PORT=5050

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=skyguard
RABBITMQ_PASS=skyguard
RABBITMQ_VHOST=skyguard

# ── Reporting ─────────────────────────────────────────────────────────────────
# Directory for Allure results (relative to project root)
ALLURE_RESULTS_DIR=reports/allure-results
